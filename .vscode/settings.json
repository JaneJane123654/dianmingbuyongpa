{
    "java.configuration.updateBuildConfiguration": "interactive",
    "code-runner.executorMap": {
        "java": "cmd /c \"cd /d $workspaceRoot && mvn -s $workspaceRoot/.mvn/settings.xml -DskipTests -pl core,desktop -am install && mvn -s $workspaceRoot/.mvn/settings.xml -f $workspaceRoot/desktop/pom.xml -DskipTests org.openjfx:javafx-maven-plugin:0.0.8:run\""
    },
    "code-runner.executorMapByFileExtension": {
        ".java": "cmd /c \"cd /d $workspaceRoot && mvn -s $workspaceRoot/.mvn/settings.xml -DskipTests -pl core,desktop -am install && mvn -s $workspaceRoot/.mvn/settings.xml -f $workspaceRoot/desktop/pom.xml -DskipTests org.openjfx:javafx-maven-plugin:0.0.8:run\""
    },
    "code-runner.runInTerminal": false
}
