<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.classroomassistant.desktop.ui.MainController">
    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="学生课堂挂机程序 v3.0" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="engineStatusLabel" text="" styleClass="info-label"/>
            <Button fx:id="settingsButton" text="设置" styleClass="secondary-button" onAction="#openSettings"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <VBox spacing="8" styleClass="status-panel">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="录音与检测状态" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="modelStatusLabel" text="" styleClass="info-label"/>
                </HBox>
                <GridPane hgap="10" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="22"/>
                        <ColumnConstraints percentWidth="78"/>
                    </columnConstraints>

                    <Label text="录音状态：" styleClass="info-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="recordingStatusLabel" text="未开始" styleClass="status-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="检测状态：" styleClass="info-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="detectionStatusLabel" text="未开始" styleClass="status-label" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="安静计时：" styleClass="info-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="quietSecondsLabel" text="0s" styleClass="status-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="录音保存：" styleClass="info-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="recordingSaveStatusLabel" text="未启用" styleClass="status-label" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <VBox spacing="8" styleClass="answer-panel" VBox.vgrow="ALWAYS">
                <Label text="课堂内容（识别）" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="lectureTextArea" editable="false" wrapText="true" prefRowCount="6"/>

                <Label text="AI 回答（流式）" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="answerTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox fx:id="logPanel" spacing="4" styleClass="status-panel" managed="true" visible="true">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="运行日志" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="clearLogButton" text="清空" styleClass="small-button" onAction="#clearLog"/>
                </HBox>
                <TextArea fx:id="logTextArea" editable="false" wrapText="true" prefRowCount="4" styleClass="log-text"/>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Button fx:id="startButton" text="上课（开始录音）" styleClass="primary-button" onAction="#startClass"/>
            <Button fx:id="stopButton" text="下课（停止录音）" styleClass="stop-button" onAction="#stopClass"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="hintLabel" text="" styleClass="info-label"/>
        </HBox>
    </bottom>
</BorderPane>
