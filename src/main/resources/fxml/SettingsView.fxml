<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.classroomassistant.ui.SettingsController">
    <top>
        <HBox spacing="10" padding="12">
            <Label text="设置" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" padding="12">
            <content>
                <VBox spacing="12">
                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="唤醒词" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="姓名/变体（逗号分隔）" styleClass="info-label"/>
                        <TextField fx:id="keywordsField" promptText="例如：张三,张三同学"/>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="安静检测（VAD）" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <CheckBox fx:id="vadEnabledCheckBox" text="启用安静检测"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="阈值（秒）" styleClass="info-label"/>
                            <Spinner fx:id="quietThresholdSpinner" editable="true"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="语音回溯" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="回溯秒数（1-300）" styleClass="info-label"/>
                            <Spinner fx:id="lookbackSecondsSpinner" editable="true"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="录音保存" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <CheckBox fx:id="recordingSaveCheckBox" text="保存触发录音（WAV）"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="保留天数（0-30）" styleClass="info-label"/>
                            <Spinner fx:id="recordingRetentionSpinner" editable="true"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="语音识别（云端 API）" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="使用 Groq Whisper 等云端服务进行语音识别" styleClass="info-label"/>
                        <Label text="Speech API Key（加密保存）" styleClass="info-label"/>
                        <PasswordField fx:id="speechApiKeyField" promptText="如 Groq API Key"/>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="AI 问答" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="模型平台" styleClass="info-label"/>
                            <ComboBox fx:id="providerComboBox" prefWidth="220"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="模型名称（可选）" styleClass="info-label"/>
                            <TextField fx:id="modelNameField" promptText="留空使用默认模型"/>
                        </HBox>
                        <Label text="Access Token / API Key（加密保存）" styleClass="info-label"/>
                        <PasswordField fx:id="tokenField" promptText="未输入则不保存"/>
                    </VBox>

                    <VBox spacing="8" styleClass="status-panel">
                        <Label text="模型管理" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="modelDownloadStatusLabel" text="" styleClass="info-label"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="openModelDownloadButton" text="打开模型管理" styleClass="secondary-button" onAction="#openModelManager"/>
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" padding="12">
            <Button text="保存" styleClass="primary-button" onAction="#save"/>
            <Button text="取消" styleClass="secondary-button" onAction="#cancel"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="" styleClass="info-label"/>
        </HBox>
    </bottom>
</BorderPane>
